# Paperis v2 환경변수 템플릿
# 실제 값은 .env.local(커밋 금지)에 넣는다.

# 필수: 자연어 → 검색식 변환 + 미니 요약 + 긴 요약 + (Gemini provider) TTS 합성
# Google AI Studio (https://aistudio.google.com)에서 발급
GEMINI_API_KEY=

# 권장: PubMed E-utilities API 키. 없어도 동작(초당 3회 제한).
# NCBI Account → Settings → API Key Management 에서 발급
PUBMED_API_KEY=

# 권장: Unpaywall API polite-pool 식별자. 풀텍스트 체인 1단계에서 사용.
# 없으면 Unpaywall 단계가 스킵되고 곧장 Europe PMC → PMC 폴백으로 진입.
UNPAYWALL_EMAIL=

# 선택: Naver Clova Voice Premium (TTS의 대안 provider).
# https://www.ncloud.com/product/aiService/clovaVoice
# 두 키 모두 있어야 동작. 사용자가 설정 패널에서 "TTS provider: Clova" 선택 시 호출됨.
# 미설정 시 호출하면 친절한 에러 — Gemini provider는 그대로 사용 가능.
NCP_CLOVA_CLIENT_ID=
NCP_CLOVA_CLIENT_SECRET=
