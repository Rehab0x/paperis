# Paperis 환경변수 템플릿
# 실제 값은 .env.local(커밋 금지)에 넣는다.

# 필수: 자연어 → 검색식 변환 + 미니 요약 + 긴 요약 + Gemini TTS(fallback)
# Google AI Studio (https://aistudio.google.com)에서 발급
GEMINI_API_KEY=

# 권장: PubMed E-utilities API 키. 없어도 동작(초당 3회 제한).
# NCBI Account → Settings → API Key Management 에서 발급
PUBMED_API_KEY=

# 권장: Unpaywall API polite-pool 식별자. 풀텍스트 체인 1단계에서 사용.
# 없으면 Unpaywall 단계가 스킵되고 곧장 Europe PMC → PMC 폴백으로 진입.
UNPAYWALL_EMAIL=

# 권장(v3 default TTS): Naver Clova Voice Premium.
# https://www.ncloud.com/product/aiService/clovaVoice
# v3부터 default TTS provider — 한국어 자연스러움 + 빠르고 안정적, Vercel timeout 회피.
# 두 키 모두 있어야 동작. 미설정 시 서버가 자동으로 Gemini TTS로 강등.
NCP_CLOVA_CLIENT_ID=
NCP_CLOVA_CLIENT_SECRET=

# 선택: Google Cloud Text-to-Speech.
# https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# Cloud Text-to-Speech API 활성화 후 API key 발급 (단순 키 인증).
# 월 1M자 무료, 그 이후 Neural2/WaveNet $16/1M자.
# GEMINI_API_KEY와는 별개의 키 (둘 다 같은 GCP 프로젝트에서 발급 가능).
GOOGLE_CLOUD_TTS_API_KEY=

# 선택: Semantic Scholar Graph API (풀텍스트 체인 5단계).
# https://www.semanticscholar.org/product/api
# 키 없이도 동작하나 rate limit 낮음. 무료 키 발급 권장.
S2_API_KEY=

# v3 M4 — Auth.js v5 + Neon Postgres + Drizzle (PR1부터)
# 4개 모두 채워야 로그인 정식 동작. 미설정 시 빌드는 통과하지만 signIn 시도가
# 그냥 실패. UI는 NEXT_PUBLIC_FEATURE_AUTH=0으로 가려두면 됨.
DATABASE_URL=
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 관리자 이메일 (콤마 구분). 이 이메일로 로그인 시:
# - 모든 LLM 호출 무제한 (Free 한도 우회)
# - 설정 → API 키 / AI provider BYOK 섹션 활성화
# - 입력 키 없으면 서버 env 키 (우리 prod 키) 사용
# 결제 흐름과 무관 — DB subscriptions 없어도 자동 BYOK 효과.
ADMIN_EMAILS=

# v3 M5 — Upstash Redis (트렌드/호 분석 캐시)
# 미설정 시 silent fallback (캐시 miss 처리, 라우트 자체는 동작).
# Vercel Marketplace → Upstash 통합 또는 console.upstash.com에서 발급.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# v3 feature flags — 개별 단계 점진 롤아웃
# 기능 검증 끝나면 prod env에서 1로 켜기. 미설정 또는 0이면 UI에서 가려짐.
NEXT_PUBLIC_FEATURE_JOURNAL=0
NEXT_PUBLIC_FEATURE_AUTH=0

# Phase 2 — 글로벌 확장 (랜딩페이지 + 영어 서비스)
# 1: / 진입 시 미들웨어가 비로그인 사용자를 /ko 또는 /en 랜딩으로 리다이렉트
#    (로그인 사용자는 /app으로). 0/미설정: / → /app 강제 (기존 v3 동작 보존).
# 라이브 회귀 발견 시 즉시 0으로 끄면 됨.
NEXT_PUBLIC_FEATURE_LANDING=0

# v3 M6 — Free 사용량 한도 (server-side flag, NEXT_PUBLIC_ X)
# 0/미설정 시 모든 호출 무제한 통과 (DB 카운트도 안 함).
# 결제 단계(M7) 도입 + prod 검증 후 1로 활성화.
FEATURE_USAGE_LIMIT=0

# v3 M7 — Toss Payments (BYOK 1회 + Pro 월 구독)
# https://app.tosspayments.com → 개발자센터 → API 키
# sandbox: test_ck_*, test_sk_*. 사업자등록 후 라이브 키 교체 (M8).
# CLIENT_KEY 두 개 등록 — backend는 secret만 쓰고 frontend는 NEXT_PUBLIC_*만 노출.
TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# v3 M8 — 사업자등록 + 라이브 결제 활성화 (default 0=sandbox)
TOSS_LIVE_MODE=0

# v3 M7 PR3 — Vercel Cron 인증 (Pro 자동결제 daily). vercel.json에 등록된 cron이
# 호출 시 Authorization: Bearer {CRON_SECRET} 헤더로 들어옴. 미설정 시 cron 자체
# 503 (외부 호출 차단). `openssl rand -hex 32` 등으로 발급.
CRON_SECRET=

# 이메일 알림 (Resend) — 미설정 시 silent skip. welcome/quota/payment 이벤트 발송.
# https://resend.com 에서 API key 발급. free tier 100/day.
RESEND_API_KEY=
# 발신자. 자체 도메인 verify 안 했으면 Resend free 발신 "onboarding@resend.dev" 사용.
# 자체 도메인 verify 후엔 "Paperis <noreply@paperis.app>" 형식.
EMAIL_FROM=Paperis <onboarding@resend.dev>
# 회신 받을 이메일 (선택)
EMAIL_REPLY_TO=
# 사이트 URL — 이메일 본문 링크에 사용. Vercel은 VERCEL_PROJECT_PRODUCTION_URL 자동
# 주입하지만 명시하면 그게 우선. local dev에선 http://localhost:3000
NEXT_PUBLIC_SITE_URL=
