# Paperis 환경변수 템플릿
# 실제 값은 .env.local(커밋 금지)에 넣는다.

# 필수: 자연어 → 검색식 변환 + 미니 요약 + 긴 요약 + Gemini TTS(fallback)
# Google AI Studio (https://aistudio.google.com)에서 발급
GEMINI_API_KEY=

# 권장: PubMed E-utilities API 키. 없어도 동작(초당 3회 제한).
# NCBI Account → Settings → API Key Management 에서 발급
PUBMED_API_KEY=

# 권장: Unpaywall API polite-pool 식별자. 풀텍스트 체인 1단계에서 사용.
# 없으면 Unpaywall 단계가 스킵되고 곧장 Europe PMC → PMC 폴백으로 진입.
UNPAYWALL_EMAIL=

# 권장(v3 default TTS): Naver Clova Voice Premium.
# https://www.ncloud.com/product/aiService/clovaVoice
# v3부터 default TTS provider — 한국어 자연스러움 + 빠르고 안정적, Vercel timeout 회피.
# 두 키 모두 있어야 동작. 미설정 시 서버가 자동으로 Gemini TTS로 강등.
NCP_CLOVA_CLIENT_ID=
NCP_CLOVA_CLIENT_SECRET=

# 선택: Google Cloud Text-to-Speech.
# https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# Cloud Text-to-Speech API 활성화 후 API key 발급 (단순 키 인증).
# 월 1M자 무료, 그 이후 Neural2/WaveNet $16/1M자.
# GEMINI_API_KEY와는 별개의 키 (둘 다 같은 GCP 프로젝트에서 발급 가능).
GOOGLE_CLOUD_TTS_API_KEY=

# v3 M4 — Auth.js v5 + Neon Postgres + Drizzle (PR1부터)
# 4개 모두 채워야 로그인 정식 동작. 미설정 시 빌드는 통과하지만 signIn 시도가
# 그냥 실패. UI는 NEXT_PUBLIC_FEATURE_AUTH=0으로 가려두면 됨.
DATABASE_URL=
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# v3 M5 — Upstash Redis (트렌드/호 분석 캐시)
# 미설정 시 silent fallback (캐시 miss 처리, 라우트 자체는 동작).
# Vercel Marketplace → Upstash 통합 또는 console.upstash.com에서 발급.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# v3 feature flags — 개별 단계 점진 롤아웃
# 기능 검증 끝나면 prod env에서 1로 켜기. 미설정 또는 0이면 UI에서 가려짐.
NEXT_PUBLIC_FEATURE_JOURNAL=0
NEXT_PUBLIC_FEATURE_AUTH=0
